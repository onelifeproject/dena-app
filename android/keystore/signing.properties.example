# Copy this file to: android/keystore/signing.properties
# Do NOT commit signing.properties or keystore files.
# Path is relative to the android/ folder.
storeFile=keystore/dena-release.keystore

# Password used when creating the keystore
storePassword=YOUR_KEYSTORE_PASSWORD

# Alias used when creating key (example: dena)
keyAlias=YOUR_KEY_ALIAS

# Key password for the alias above
keyPassword=YOUR_KEY_PASSWORD
